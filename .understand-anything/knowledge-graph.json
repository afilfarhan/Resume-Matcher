                 },
                 {
                     "files":  [
                                   "apps/frontend/app/(default)/",
                                   "apps/frontend/components/",
                                   "apps/frontend/lib/api/"
                               ],
                     "step":  6,
                     "description":  "Next.js 16 App Router with TypeScript. Pages in app/(default)/, components in components/, API client in lib/api/. The Swiss design system is mandatory for all UI.",
                     "title":  "Frontend Architecture"
                 },
                 {
                     "files":  [
                                   "apps/frontend/lib/api/client.ts",
                                   "apps/frontend/lib/api/"
                               ],
                     "step":  7,
                     "description":  "lib/api/client.ts provides centralized API access with 240s timeout. The client exports apiFetch, apiPost, apiPatch, apiPut, apiDelete functions. Never use raw fetch in components.",
                     "title":  "API Client"
                 },
                 {
                     "files":  [
                                   "apps/frontend/lib/i18n/",
                                   "apps/frontend/i18n/",
                                   "apps/frontend/messages/"
                               ],
                     "step":  8,
                     "description":  "Custom i18n system with locale parity. Two settings: uiLanguage (interface) and contentLanguage (LLM output). Supported locales: en, es, zh, ja, pt. All translation files must match en.json structurally.",
                     "title":  "Internationalization"
                 },
                 {
                     "files":  [
                                   "apps/frontend/components/tracker/",
                                   "apps/backend/app/routers/applications.py"
                               ],
                     "step":  9,
                     "description":  "Kanban board for job applications using dnd-kit. Seven columns: saved, applied, no_response, response, interview, accepted, rejected. Supports bulk operations and manual addition.",
                     "title":  "Tracker System"
